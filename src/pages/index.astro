---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import ShaderBackground from '../components/ShaderBackground.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<ShaderBackground />
		<main>
			<section class="hero-container">
				<div class="hero-header">
					<h2 class="site-name"><a href="/">Manu MA</a></h2>
					<nav class="nav-center">
						<a href="/">Home</a>
						<a href="/blog">Blog</a>
						<a href="/about">About</a>
					</nav>
					<div class="social-links">
						<a href="https://github.com/manucorporat" target="_blank">GitHub</a>
						<a href="https://www.linkedin.com/in/manu-mart%C3%ADnez-almeida-5b390539/" target="_blank">LinkedIn</a>
						<a href="https://twitter.com/manucorporat" target="_blank">Twitter</a>
					</div>
				</div>
				
				<div class="hero-content">
					<h1>Hello 👋</h1>
					<p class="intro">
						I'm <strong>Manu MA</strong>, an open source developer and tech innovator.
						Creator of <a href="https://github.com/gin-gonic/gin" target="_blank">Gin</a>,
						co-creator of <a href="https://qwik.dev" target="_blank">Qwik</a> and
						<a href="https://stenciljs.com" target="_blank">Stencil</a>, and founder of
						<a href="https://set.health" target="_blank">set.health</a>.
					</p>
				</div>

				<div class="hero-footer">
					<span class="location">Spain</span>
				</div>
			</section>

			<section class="projects-section">
				<h2>Featured Work</h2>
				<div class="cards-grid">
					<article class="project-card">
						<div class="card-header">
							<span class="project-date">2014 - Present</span>
							<span class="project-id">ID 001</span>
						</div>
						<h3>
							<a href="https://github.com/gin-gonic/gin" target="_blank">Gin</a>
						</h3>
						<p class="project-meta">Go Framework • 86.3k ★</p>
						<p>
							High-performance HTTP web framework for Go. Up to 40x faster than alternatives,
							powering thousands of production applications worldwide.
						</p>
						<div class="card-badge"></div>
					</article>

					<article class="project-card">
						<div class="card-header">
							<span class="project-date">2022 - Present</span>
							<span class="project-id">ID 002</span>
						</div>
						<h3>
							<a href="https://github.com/QwikDev/qwik" target="_blank">Qwik</a>
						</h3>
						<p class="project-meta">Web Framework • 21.7k ★</p>
						<p>
							Instant-loading web apps without effort. Revolutionary framework that delivers
							O(1) loading time regardless of application complexity.
						</p>
						<div class="card-badge"></div>
					</article>

					<article class="project-card">
						<div class="card-header">
							<span class="project-date">2016 - 2022</span>
							<span class="project-id">ID 003</span>
						</div>
						<h3>
							<a href="https://github.com/ionic-team/ionic-framework" target="_blank">Ionic</a>
						</h3>
						<p class="project-meta">Mobile Framework • 52.1k ★</p>
						<p>
							Core developer of the powerful cross-platform UI toolkit for building native-quality
							iOS, Android, and Progressive Web Apps.
						</p>
						<div class="card-badge"></div>
					</article>

					<article class="project-card">
						<div class="card-header">
							<span class="project-date">2017 - 2022</span>
							<span class="project-id">ID 004</span>
						</div>
						<h3>
							<a href="https://github.com/stenciljs/core" target="_blank">Stencil</a>
						</h3>
						<p class="project-meta">Web Components • 12.9k ★</p>
						<p>
							Co-creator of the toolchain for building scalable, enterprise-ready component systems
							on top of Web Components.
						</p>
						<div class="card-badge"></div>
					</article>

					<article class="project-card">
						<div class="card-header">
							<span class="project-date">2023 - Present</span>
							<span class="project-id">ID 005</span>
						</div>
						<h3>
							<a href="https://set.health" target="_blank">set.health</a>
						</h3>
						<p class="project-meta">Healthcare Tech • Founder</p>
						<p>
							Healthcare technology startup focused on improving patient care through innovative
							digital solutions.
						</p>
						<div class="card-badge"></div>
					</article>

					<article class="project-card">
						<div class="card-header">
							<span class="project-date">2015 - Present</span>
							<span class="project-id">ID 006</span>
						</div>
						<h3>
							<a href="https://github.com/manucorporat/sse" target="_blank">SSE</a>
						</h3>
						<p class="project-meta">Real-time • 278 ★</p>
						<p>
							Server-Sent Events implementation in Go, used by the Gin framework for real-time
							communication.
						</p>
						<div class="card-badge"></div>
					</article>
				</div>
			</section>

			<section class="timeline-section">
				<h2>Experience</h2>
				<div class="timeline-card">
					<div class="timeline-items">
						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>Builder.io</h3>
								<p class="role">Senior Engineer</p>
								<p class="description">Working on cutting-edge web technologies and developer tools</p>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>Qwik</h3>
								<p class="role">Co-creator</p>
								<p class="description">Revolutionary framework for instant-loading web applications</p>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>Stencil</h3>
								<p class="role">Co-creator</p>
								<p class="description">Web Components compiler for building design systems</p>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>Ionic</h3>
								<p class="role">Core Developer</p>
								<p class="description">Core contributor to cross-platform framework</p>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>Gin Framework</h3>
								<p class="role">Creator & Maintainer</p>
								<p class="description">Created the most popular Go web framework</p>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>HTML Specification</h3>
								<p class="role">Contributor</p>
								<p class="description">Contributed to the evolution of web standards</p>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		position: relative;
		z-index: 1;
		padding: 2em 1.5em;
		max-width: 1200px;
		margin: 0 auto;
	}

	.hero-container {
		background: rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(20px) saturate(1.5);
		-webkit-backdrop-filter: blur(20px) saturate(1.5);
		border: 1px solid rgba(255, 255, 255, 0.5);
		border-radius: 20px;
		padding: 2.5em;
		margin-bottom: 2em;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1),
		            0 0 0 1px rgba(255, 255, 255, 0.2) inset;
		min-height: 65vh;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.hero-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 3em;
	}

	.site-name {
		margin: 0;
		font-size: 1.1em;
		font-weight: 700;
	}

	.site-name a {
		color: rgb(var(--black));
		text-decoration: none;
	}

	.nav-center {
		display: flex;
		gap: 2em;
		align-items: center;
	}

	.nav-center a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-weight: 500;
		font-size: 0.95em;
		transition: color 0.2s;
	}

	.nav-center a:hover {
		color: rgb(var(--black));
	}

	.social-links {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
		align-items: flex-end;
	}

	.social-links a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.9em;
		transition: color 0.2s;
	}

	.social-links a:hover {
		color: rgb(var(--black));
	}

	.hero-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		max-width: 700px;
	}

	.hero-content h1 {
		font-size: 4.5em;
		margin-bottom: 0.4em;
		color: rgb(var(--black));
		font-weight: 700;
		line-height: 1.1;
	}

	.intro {
		font-size: 1.25em;
		line-height: 1.7;
		color: rgb(var(--gray-dark));
	}

	.intro strong {
		color: rgb(var(--black));
		font-weight: 600;
	}

	.intro a {
		color: rgb(var(--black));
		text-decoration: underline;
		text-decoration-color: var(--accent);
		text-decoration-thickness: 2px;
		text-underline-offset: 3px;
	}

	.intro a:hover {
		color: var(--accent-dark);
		text-decoration-color: var(--accent-dark);
	}

	.hero-footer {
		display: flex;
		justify-content: flex-end;
		margin-top: 2em;
	}

	.location {
		font-size: 0.9em;
		color: rgb(var(--gray));
		font-style: italic;
	}

	.projects-section,
	.timeline-section {
		margin-bottom: 2em;
	}

	h2 {
		font-size: 1.5em;
		margin-bottom: 1.5em;
		color: rgb(var(--black));
		font-weight: 600;
		padding-left: 0.5em;
	}

	.cards-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 1.5em;
	}

	.project-card {
		background: var(--bg-card);
		border-radius: 18px;
		padding: 2em;
		box-shadow: var(--box-shadow);
		position: relative;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.project-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1em;
		font-size: 0.8em;
	}

	.project-date {
		color: rgb(var(--gray));
		font-weight: 400;
	}

	.project-id {
		color: rgb(var(--gray));
		font-weight: 600;
	}

	.project-card h3 {
		margin: 0 0 0.5em 0;
		font-size: 1.8em;
		font-weight: 700;
	}

	.project-card h3 a {
		color: rgb(var(--black));
		text-decoration: none;
	}

	.project-card h3 a:hover {
		color: var(--accent-dark);
	}

	.project-meta {
		font-size: 0.85em;
		color: rgb(var(--gray));
		font-weight: 600;
		margin: 0 0 1em 0;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.project-card p:last-of-type {
		color: rgb(var(--gray-dark));
		line-height: 1.6;
		margin: 0;
		padding-bottom: 2em;
	}

	.card-badge {
		position: absolute;
		bottom: 1.5em;
		right: 1.5em;
		width: 12px;
		height: 12px;
		background: var(--accent);
		border-radius: 50%;
	}

	.timeline-card {
		background: var(--bg-card);
		border-radius: 18px;
		padding: 2.5em;
		box-shadow: var(--box-shadow);
	}

	.timeline-items {
		display: flex;
		flex-direction: column;
		gap: 2em;
	}

	.timeline-item {
		display: flex;
		gap: 1.5em;
		position: relative;
	}

	.timeline-item:not(:last-child)::after {
		content: '';
		position: absolute;
		left: 9px;
		top: 30px;
		bottom: -30px;
		width: 2px;
		background: rgb(var(--gray-light));
	}

	.timeline-dot {
		width: 20px;
		height: 20px;
		background: var(--accent);
		border-radius: 50%;
		flex-shrink: 0;
		margin-top: 4px;
		box-shadow: 0 0 0 4px var(--bg-card);
	}

	.timeline-content h3 {
		margin: 0 0 0.3em 0;
		font-size: 1.3em;
		color: rgb(var(--black));
		font-weight: 600;
	}

	.role {
		font-size: 0.95em;
		color: rgb(var(--gray));
		font-weight: 600;
		margin: 0 0 0.5em 0;
	}

	.description {
		color: rgb(var(--gray-dark));
		margin: 0;
		line-height: 1.5;
	}

	@media (max-width: 900px) {
		.hero-header {
			flex-direction: column;
			gap: 1.5em;
		}

		.nav-center {
			order: 2;
			gap: 1.5em;
		}

		.social-links {
			order: 1;
			flex-direction: row;
			align-items: center;
			align-self: flex-start;
			gap: 1.5em;
		}

		.hero-content h1 {
			font-size: 3em;
		}

		.intro {
			font-size: 1.1em;
		}
	}

	@media (max-width: 720px) {
		main {
			padding: 1em;
		}

		.hero-container {
			padding: 2em 1.5em;
			min-height: auto;
		}

		.hero-content h1 {
			font-size: 2.5em;
		}

		.intro {
			font-size: 1em;
		}

		.cards-grid {
			grid-template-columns: 1fr;
		}

		.timeline-card {
			padding: 1.5em;
		}

		h2 {
			padding-left: 0;
		}

		.nav-center {
			gap: 1em;
		}

		.nav-center a,
		.social-links a {
			font-size: 0.85em;
		}
	}
</style>
