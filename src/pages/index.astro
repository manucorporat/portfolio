---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ShaderBackground from '../components/ShaderBackground.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<ShaderBackground />
		<Header />
		<main>
			<section class="hero">
				<h1>Manu MA</h1>
				<p class="subtitle">Open Source Developer & Tech Innovator</p>
				<p class="bio">
					Creator of <a href="https://github.com/gin-gonic/gin" target="_blank">Gin</a> (86k+ stars),
					co-creator of <a href="https://qwik.dev" target="_blank">Qwik</a> and
					<a href="https://stenciljs.com" target="_blank">Stencil</a>, Ionic core developer,
					and founder of <a href="https://set.health" target="_blank">set.health</a>.
				</p>
			</section>

			<section class="featured-projects">
				<h2>Featured Projects</h2>
				<div class="projects-grid">
					<article class="project-card">
						<h3>
							<a href="https://github.com/gin-gonic/gin" target="_blank">Gin</a>
						</h3>
						<p class="project-meta">Go • 86.3k stars</p>
						<p>
							High-performance HTTP web framework for Go. Up to 40x faster than alternatives,
							powering thousands of production applications worldwide.
						</p>
					</article>

					<article class="project-card">
						<h3>
							<a href="https://github.com/QwikDev/qwik" target="_blank">Qwik</a>
						</h3>
						<p class="project-meta">TypeScript • 21.7k stars</p>
						<p>
							Instant-loading web apps without effort. Revolutionary framework that delivers
							O(1) loading time regardless of application complexity.
						</p>
					</article>

					<article class="project-card">
						<h3>
							<a href="https://github.com/ionic-team/ionic-framework" target="_blank">Ionic Framework</a>
						</h3>
						<p class="project-meta">TypeScript • 52.1k stars</p>
						<p>
							Core developer of the powerful cross-platform UI toolkit for building native-quality
							iOS, Android, and Progressive Web Apps.
						</p>
					</article>

					<article class="project-card">
						<h3>
							<a href="https://github.com/stenciljs/core" target="_blank">Stencil</a>
						</h3>
						<p class="project-meta">TypeScript • 12.9k stars</p>
						<p>
							Co-creator of the toolchain for building scalable, enterprise-ready component systems
							on top of Web Components.
						</p>
					</article>

					<article class="project-card">
						<h3>
							<a href="https://github.com/manucorporat/sse" target="_blank">SSE</a>
						</h3>
						<p class="project-meta">Go • 278 stars</p>
						<p>
							Server-Sent Events implementation in Go, used by the Gin framework for real-time
							communication.
						</p>
					</article>

					<article class="project-card">
						<h3>
							<a href="https://set.health" target="_blank">set.health</a>
						</h3>
						<p class="project-meta">Founder</p>
						<p>
							Healthcare technology startup focused on improving patient care through innovative
							digital solutions.
						</p>
					</article>
				</div>
			</section>

			<section class="experience">
				<h2>Experience & Contributions</h2>
				<div class="timeline">
					<div class="timeline-item">
						<h3>Builder.io</h3>
						<p class="role">Senior Engineer</p>
						<p>Working on cutting-edge web technologies and developer tools</p>
					</div>

					<div class="timeline-item">
						<h3>Qwik</h3>
						<p class="role">Co-creator</p>
						<p>Revolutionary framework for instant-loading web applications</p>
					</div>

					<div class="timeline-item">
						<h3>Stencil</h3>
						<p class="role">Co-creator</p>
						<p>Web Components compiler for building design systems and component libraries</p>
					</div>

					<div class="timeline-item">
						<h3>Ionic</h3>
						<p class="role">Core Developer</p>
						<p>Core contributor to one of the most popular cross-platform frameworks</p>
					</div>

					<div class="timeline-item">
						<h3>Gin Framework</h3>
						<p class="role">Creator & Maintainer</p>
						<p>Created the most popular Go web framework with 86k+ stars</p>
					</div>

					<div class="timeline-item">
						<h3>HTML Specification</h3>
						<p class="role">Contributor</p>
						<p>Contributed to the evolution of web standards</p>
					</div>

					<div class="timeline-item">
						<h3>Cocos2d</h3>
						<p class="role">Top Contributor</p>
						<p>Major contributions to the popular game development framework</p>
					</div>
				</div>
			</section>

			<section class="early-work">
				<h2>Early Projects</h2>
				<p>
					Started coding at a young age, creating games and interactive experiences.
					Founded FORZEFIELD Studios at 15, developing <strong>Infinity Field</strong> - a dual-stick
					shooter for iOS with multiplayer capabilities, featured by IGN, AppSpy, and other major outlets.
				</p>
				<p class="shader-note">
					<em>Background: Electric field simulation shader - one of many WebGL experiments</em>
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		position: relative;
		z-index: 1;
	}

	.hero {
		text-align: center;
		padding: 4em 0 3em;
		margin-bottom: 2em;
	}

	.hero h1 {
		font-size: 4em;
		margin-bottom: 0.2em;
		background: linear-gradient(135deg, #fff 0%, #a0a0ff 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.subtitle {
		font-size: 1.5em;
		color: #fff;
		margin-bottom: 1em;
		font-weight: 600;
	}

	.bio {
		font-size: 1.1em;
		max-width: 800px;
		margin: 0 auto;
		line-height: 1.8;
		color: #e0e0ff;
	}

	.bio a {
		color: #88ff88;
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: border-color 0.3s;
	}

	.bio a:hover {
		border-bottom-color: #88ff88;
	}

	section {
		margin-bottom: 4em;
		background: rgba(255, 255, 255, 0.95);
		padding: 2em;
		border-radius: 12px;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
	}

	.hero {
		background: transparent;
		box-shadow: none;
	}

	h2 {
		color: rgb(var(--black));
		border-bottom: 3px solid var(--accent);
		padding-bottom: 0.5em;
		margin-bottom: 1.5em;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 1.5em;
	}

	.project-card {
		background: linear-gradient(135deg, #f8f9ff 0%, #ffffff 100%);
		padding: 1.5em;
		border-radius: 8px;
		border: 2px solid #e0e0ff;
		transition: transform 0.3s, box-shadow 0.3s;
	}

	.project-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(35, 55, 255, 0.15);
	}

	.project-card h3 {
		margin-top: 0;
		margin-bottom: 0.5em;
	}

	.project-card h3 a {
		color: var(--accent-dark);
		text-decoration: none;
	}

	.project-card h3 a:hover {
		color: var(--accent);
	}

	.project-meta {
		font-size: 0.9em;
		color: rgb(var(--gray));
		margin-bottom: 1em;
		font-weight: 600;
	}

	.project-card p:last-child {
		margin-bottom: 0;
	}

	.timeline {
		display: flex;
		flex-direction: column;
		gap: 1.5em;
	}

	.timeline-item {
		padding-left: 2em;
		border-left: 3px solid var(--accent);
		position: relative;
	}

	.timeline-item::before {
		content: '';
		position: absolute;
		left: -8px;
		top: 0;
		width: 13px;
		height: 13px;
		background: var(--accent);
		border-radius: 50%;
	}

	.timeline-item h3 {
		margin-top: 0;
		margin-bottom: 0.3em;
		color: rgb(var(--black));
	}

	.role {
		font-weight: 600;
		color: var(--accent-dark);
		margin-bottom: 0.5em;
	}

	.timeline-item p:last-child {
		margin-bottom: 0;
		color: rgb(var(--gray-dark));
	}

	.early-work p {
		margin-bottom: 1em;
	}

	.shader-note {
		font-size: 0.9em;
		color: rgb(var(--gray));
		margin-top: 2em;
		padding-top: 1em;
		border-top: 1px solid rgb(var(--gray-light));
	}

	@media (max-width: 720px) {
		.hero h1 {
			font-size: 2.5em;
		}

		.subtitle {
			font-size: 1.2em;
		}

		.bio {
			font-size: 1em;
		}

		section {
			padding: 1.5em;
		}

		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
