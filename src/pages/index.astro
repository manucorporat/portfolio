---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ShaderBackground from '../components/ShaderBackground.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<ShaderBackground />
		<Header />
		<main>
			<section class="hero-card">
				<div class="greeting">
					<h1>Hello 👋</h1>
					<p class="intro">
						I'm <strong>Manu MA</strong>, an open source developer and tech innovator.
						Creator of <a href="https://github.com/gin-gonic/gin" target="_blank">Gin</a>,
						co-creator of <a href="https://qwik.dev" target="_blank">Qwik</a> and
						<a href="https://stenciljs.com" target="_blank">Stencil</a>, and founder of
						<a href="https://set.health" target="_blank">set.health</a>.
					</p>
				</div>
			</section>

			<section class="projects-section">
				<h2>Featured Work</h2>
				<div class="cards-grid">
					<article class="project-card">
						<div class="card-header">
							<span class="project-label">Go Framework</span>
							<span class="project-stars">86.3k ★</span>
						</div>
						<h3>
							<a href="https://github.com/gin-gonic/gin" target="_blank">Gin</a>
						</h3>
						<p>
							High-performance HTTP web framework for Go. Up to 40x faster than alternatives,
							powering thousands of production applications worldwide.
						</p>
						<div class="card-badge"></div>
					</article>

					<article class="project-card">
						<div class="card-header">
							<span class="project-label">Web Framework</span>
							<span class="project-stars">21.7k ★</span>
						</div>
						<h3>
							<a href="https://github.com/QwikDev/qwik" target="_blank">Qwik</a>
						</h3>
						<p>
							Instant-loading web apps without effort. Revolutionary framework that delivers
							O(1) loading time regardless of application complexity.
						</p>
						<div class="card-badge"></div>
					</article>

					<article class="project-card">
						<div class="card-header">
							<span class="project-label">Mobile Framework</span>
							<span class="project-stars">52.1k ★</span>
						</div>
						<h3>
							<a href="https://github.com/ionic-team/ionic-framework" target="_blank">Ionic</a>
						</h3>
						<p>
							Core developer of the powerful cross-platform UI toolkit for building native-quality
							iOS, Android, and Progressive Web Apps.
						</p>
						<div class="card-badge"></div>
					</article>

					<article class="project-card">
						<div class="card-header">
							<span class="project-label">Web Components</span>
							<span class="project-stars">12.9k ★</span>
						</div>
						<h3>
							<a href="https://github.com/stenciljs/core" target="_blank">Stencil</a>
						</h3>
						<p>
							Co-creator of the toolchain for building scalable, enterprise-ready component systems
							on top of Web Components.
						</p>
						<div class="card-badge"></div>
					</article>

					<article class="project-card">
						<div class="card-header">
							<span class="project-label">Healthcare Tech</span>
							<span class="project-stars">Founder</span>
						</div>
						<h3>
							<a href="https://set.health" target="_blank">set.health</a>
						</h3>
						<p>
							Healthcare technology startup focused on improving patient care through innovative
							digital solutions.
						</p>
						<div class="card-badge"></div>
					</article>

					<article class="project-card">
						<div class="card-header">
							<span class="project-label">Real-time</span>
							<span class="project-stars">278 ★</span>
						</div>
						<h3>
							<a href="https://github.com/manucorporat/sse" target="_blank">SSE</a>
						</h3>
						<p>
							Server-Sent Events implementation in Go, used by the Gin framework for real-time
							communication.
						</p>
						<div class="card-badge"></div>
					</article>
				</div>
			</section>

			<section class="timeline-section">
				<h2>Experience</h2>
				<div class="timeline-card">
					<div class="timeline-items">
						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>Builder.io</h3>
								<p class="role">Senior Engineer</p>
								<p class="description">Working on cutting-edge web technologies and developer tools</p>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>Qwik</h3>
								<p class="role">Co-creator</p>
								<p class="description">Revolutionary framework for instant-loading web applications</p>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>Stencil</h3>
								<p class="role">Co-creator</p>
								<p class="description">Web Components compiler for building design systems</p>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>Ionic</h3>
								<p class="role">Core Developer</p>
								<p class="description">Core contributor to cross-platform framework</p>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>Gin Framework</h3>
								<p class="role">Creator & Maintainer</p>
								<p class="description">Created the most popular Go web framework</p>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<h3>HTML Specification</h3>
								<p class="role">Contributor</p>
								<p class="description">Contributed to the evolution of web standards</p>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		position: relative;
		z-index: 1;
	}

	.hero-card {
		background: var(--bg-card);
		border-radius: 18px;
		padding: 3em 2.5em;
		margin-bottom: 2em;
		box-shadow: var(--box-shadow);
	}

	.greeting h1 {
		font-size: 3.5em;
		margin-bottom: 0.5em;
		color: rgb(var(--black));
		font-weight: 700;
	}

	.intro {
		font-size: 1.1em;
		line-height: 1.7;
		color: rgb(var(--gray-dark));
		max-width: 700px;
	}

	.intro strong {
		color: rgb(var(--black));
		font-weight: 600;
	}

	.intro a {
		color: rgb(var(--black));
		text-decoration: underline;
		text-decoration-color: var(--accent);
		text-decoration-thickness: 2px;
		text-underline-offset: 3px;
	}

	.intro a:hover {
		color: var(--accent-dark);
		text-decoration-color: var(--accent-dark);
	}

	.projects-section,
	.timeline-section {
		margin-bottom: 2em;
	}

	h2 {
		font-size: 1.5em;
		margin-bottom: 1.5em;
		color: rgb(var(--black));
		font-weight: 600;
		padding-left: 0.5em;
	}

	.cards-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 1.5em;
	}

	.project-card {
		background: var(--bg-card);
		border-radius: 18px;
		padding: 2em;
		box-shadow: var(--box-shadow);
		position: relative;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.project-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1em;
		font-size: 0.85em;
	}

	.project-label {
		color: rgb(var(--gray));
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.project-stars {
		color: rgb(var(--gray));
		font-weight: 600;
	}

	.project-card h3 {
		margin: 0 0 0.8em 0;
		font-size: 1.8em;
		font-weight: 700;
	}

	.project-card h3 a {
		color: rgb(var(--black));
		text-decoration: none;
	}

	.project-card h3 a:hover {
		color: var(--accent-dark);
	}

	.project-card p {
		color: rgb(var(--gray-dark));
		line-height: 1.6;
		margin: 0;
		padding-bottom: 2em;
	}

	.card-badge {
		position: absolute;
		bottom: 1.5em;
		right: 1.5em;
		width: 12px;
		height: 12px;
		background: var(--accent);
		border-radius: 50%;
	}

	.timeline-card {
		background: var(--bg-card);
		border-radius: 18px;
		padding: 2.5em;
		box-shadow: var(--box-shadow);
	}

	.timeline-items {
		display: flex;
		flex-direction: column;
		gap: 2em;
	}

	.timeline-item {
		display: flex;
		gap: 1.5em;
		position: relative;
	}

	.timeline-item:not(:last-child)::after {
		content: '';
		position: absolute;
		left: 9px;
		top: 30px;
		bottom: -30px;
		width: 2px;
		background: rgb(var(--gray-light));
	}

	.timeline-dot {
		width: 20px;
		height: 20px;
		background: var(--accent);
		border-radius: 50%;
		flex-shrink: 0;
		margin-top: 4px;
		box-shadow: 0 0 0 4px var(--bg-card);
	}

	.timeline-content h3 {
		margin: 0 0 0.3em 0;
		font-size: 1.3em;
		color: rgb(var(--black));
		font-weight: 600;
	}

	.role {
		font-size: 0.95em;
		color: rgb(var(--gray));
		font-weight: 600;
		margin: 0 0 0.5em 0;
	}

	.description {
		color: rgb(var(--gray-dark));
		margin: 0;
		line-height: 1.5;
	}

	@media (max-width: 720px) {
		.hero-card {
			padding: 2em 1.5em;
		}

		.greeting h1 {
			font-size: 2.5em;
		}

		.intro {
			font-size: 1em;
		}

		.cards-grid {
			grid-template-columns: 1fr;
		}

		.timeline-card {
			padding: 1.5em;
		}

		h2 {
			padding-left: 0;
		}
	}
</style>
