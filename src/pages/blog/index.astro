---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import ShaderBackground from '../../components/ShaderBackground.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<ShaderBackground />
		<main>
			<nav class="top-nav">
				<h2 class="site-name"><a href="/">Manu MA</a></h2>
				<div class="nav-center">
					<a href="/">Home</a>
					<a href="/blog" class="active">Blog</a>
					<a href="/about">About</a>
				</div>
				<div class="social-links">
					<a href="https://github.com/manucorporat" target="_blank">GitHub</a>
					<a href="https://www.linkedin.com/in/manu-mart%C3%ADnez-almeida-5b390539/" target="_blank">LinkedIn</a>
					<a href="https://twitter.com/manucorporat" target="_blank">Twitter</a>
				</div>
			</nav>

			<section class="blog-section">
				<h1>Blog</h1>
				<ul class="posts-grid">
					{
						posts.map((post) => (
							<li class="post-card">
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="post-title">{post.data.title}</h4>
									<p class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: 2em 1.5em;
		max-width: 1200px;
		margin: 0 auto;
	}

	.top-nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2em;
	}

	.site-name {
		margin: 0;
		font-size: 1.1em;
		font-weight: 700;
	}

	.site-name a {
		color: rgb(var(--black));
		text-decoration: none;
	}

	.nav-center {
		display: flex;
		gap: 2em;
		align-items: center;
	}

	.nav-center a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-weight: 500;
		font-size: 0.95em;
		transition: color 0.2s;
	}

	.nav-center a:hover,
	.nav-center a.active {
		color: rgb(var(--black));
	}

	.social-links {
		display: flex;
		gap: 1.5em;
		align-items: center;
	}

	.social-links a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.9em;
		transition: color 0.2s;
	}

	.social-links a:hover {
		color: rgb(var(--black));
	}

	.blog-section h1 {
		font-size: 2.5em;
		margin-bottom: 1.5em;
		color: rgb(var(--black));
		font-weight: 700;
		padding-left: 0.5em;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
		gap: 1.5em;
		list-style-type: none;
		margin: 0;
		padding: 0;
	}

	.post-card {
		background: var(--bg-card);
		border-radius: 18px;
		overflow: hidden;
		box-shadow: var(--box-shadow);
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.post-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
	}

	.post-card a {
		display: block;
		text-decoration: none;
	}

	.post-card img {
		width: 100%;
		height: 200px;
		object-fit: cover;
		margin-bottom: 0;
		border-radius: 0;
	}

	.post-title {
		margin: 1em 1.5em 0.5em;
		color: rgb(var(--black));
		line-height: 1.3;
		font-size: 1.3em;
		font-weight: 600;
	}

	.post-date {
		margin: 0 1.5em 1.5em;
		color: rgb(var(--gray));
		font-size: 0.9em;
	}

	.post-card:hover .post-title {
		color: var(--accent-dark);
	}

	@media (max-width: 900px) {
		.top-nav {
			flex-direction: column;
			gap: 1.5em;
			align-items: flex-start;
		}

		.social-links {
			align-self: flex-start;
		}
	}

	@media (max-width: 720px) {
		main {
			padding: 1em;
		}

		.posts-grid {
			grid-template-columns: 1fr;
		}

		.blog-section h1 {
			padding-left: 0;
			font-size: 2em;
		}

		.social-links {
			display: none;
		}

		.nav-center {
			gap: 1em;
		}
	}
</style>
